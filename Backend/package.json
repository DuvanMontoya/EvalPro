{
  "name": "evalpro-backend",
  "version": "1.0.0",
  "description": "API REST y WebSocket para EvalPro",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "runtime:reparar": "powershell -ExecutionPolicy Bypass -File scripts/reparar-backend-runtime.ps1",
    "pruebas:e2e": "jest --config ./test/ConfiguracionPruebasE2e.cjs --runInBand",
    "pruebas:e2e:ci": "npm run pruebas:e2e -- --ci",
    "datos:limpiar:qa": "ts-node scripts/limpiar-datos-qa.ts --apply",
    "datos:limpiar:qa:dry": "ts-node scripts/limpiar-datos-qa.ts",
    "prisma:generar": "prisma generate",
    "prisma:migrar": "prisma migrate dev --name inicio",
    "prisma:sembrar": "prisma db seed"
  },
  "prisma": {
    "seed": "ts-node prisma/Semillas/Semilla.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/websockets": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.19",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "jest": "^30.1.3",
    "prisma": "^5.22.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
