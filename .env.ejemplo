# ------------------------------------------------------------------------------
# EvalPro - Variables globales para docker-compose y ejecucion local
# Copia este archivo como .env en la raiz del proyecto.
# ------------------------------------------------------------------------------

# PostgreSQL (orquestacion Docker)
POSTGRES_USUARIO=evalpro_usuario
POSTGRES_CONTRASENA=evalpro_contrasena_segura
POSTGRES_BASE_DATOS=evalPro_db
POSTGRES_PUERTO=5432

# Backend (AGENTS.md raiz - requeridas)
DATABASE_URL=postgresql://evalpro_usuario:evalpro_contrasena_segura@localhost:5432/evalPro_db?schema=public
JWT_SECRETO_ACCESO=minimo_64_caracteres_completamente_aleatorios_acceso
JWT_EXPIRACION_ACCESO=15m
JWT_SECRETO_REFRESH=minimo_64_caracteres_completamente_aleatorios_refresh
JWT_EXPIRACION_REFRESH=180d
JWT_EMISOR=evalpro-backend
JWT_AUDIENCIA=evalpro-cliente
PUERTO_APP=3001
HOST_APP=0.0.0.0
CORS_ORIGENES_PERMITIDOS=http://localhost:3000
ENTORNO=desarrollo
BCRYPT_RONDAS_HASH=12
ADMIN_CORREO_INICIAL=admin@institucion.edu
ADMIN_CONTRASENA_INICIAL=CAMBIAR_POR_CLAVE_SEGURA_ADMIN
SUPERADMIN_CORREO_INICIAL=superadmin@institucion.edu
SUPERADMIN_CONTRASENA_INICIAL=CAMBIAR_POR_CLAVE_SEGURA_SUPERADMIN
DOCENTE_CORREO_INICIAL=docente@institucion.edu
DOCENTE_CONTRASENA_INICIAL=CAMBIAR_POR_CLAVE_SEGURA_DOCENTE
ESTUDIANTE_CORREO_INICIAL=estudiante@institucion.edu
ESTUDIANTE_CONTRASENA_INICIAL=CAMBIAR_POR_CLAVE_SEGURA_ESTUDIANTE
INSTITUCION_NOMBRE_INICIAL=EvalPro Institucion Inicial
INSTITUCION_DOMINIO_INICIAL=institucion.local
PERIODO_NOMBRE_INICIAL=2026-1
GRUPO_NOMBRE_INICIAL=Grupo Inicial EvalPro
GRUPO_DESCRIPCION_INICIAL=Grupo inicial configurado desde variables de entorno
TELEMETRIA_SEGUNDOS_MINIMOS_POR_PREGUNTA=3
TELEMETRIA_MAX_EVENTOS_SEGUNDO_PLANO=0
TELEMETRIA_RED_VENTANA_SEGUNDOS=120
TELEMETRIA_RED_MAX_RECONECIONES_VENTANA=3
TELEMETRIA_RED_MAX_CAMBIOS_TIPO_VENTANA=4
TELEMETRIA_RED_MAX_OFFLINE_SEGUNDOS=90
TELEMETRIA_RED_RIESGO_RECONECION=8
TELEMETRIA_RED_RIESGO_CAMBIO_TIPO=6
TELEMETRIA_RED_RIESGO_OFFLINE=10
TELEMETRIA_RED_UMBRAL_SOSPECHA=30
TELEMETRIA_RED_UMBRAL_CRITICO=60
INTEGRIDAD_REQUERIR_REPORTE_ANDROID=true
INTEGRIDAD_REQUERIR_BLOQUEO_ESTRICTO_ANDROID=true
INTEGRIDAD_PERMITIR_EMULADOR=false
INTEGRIDAD_PERMITIR_COMPILACION_DEBUG=false
INTEGRIDAD_PERMITIR_OPCIONES_DESARROLLADOR=false
INTEGRIDAD_PERMITIR_ADB=false
INTEGRIDAD_RIESGO_BLOQUEO_UMBRAL=60

# Frontend (AGENTS.md raiz - requeridas)
PUERTO_FRONTEND=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WEBSOCKET_URL=http://localhost:3001
NEXT_PUBLIC_VERSION_APP=1.0.0
API_BASE_INTERNA=http://backend:3001/api/v1
